        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EKycRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EKycRequest"
              }
            },
            "application/*+json": {
